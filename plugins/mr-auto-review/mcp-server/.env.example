# MR-auto-review MCP server — env template
# Copy to .env (gitignored) and fill in the values you actually need.

# Dedicated PAT for the plugin. Preferred over the token embedded in
# `git remote get-url origin`. Scope required: api (read+write).
# Example: Vixx-MR-auto-reviewer (Wetaca).
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxxxx

# Set to 1 to enable the integration test (test/gitlab/integration.test.ts).
# The test creates a probe discussion on the MR indicated below.
GITLAB_INTEGRATION=0

# IID of an MR safe to write a probe comment to. The probe body starts with
# `🤖 MR-auto-review · integration-probe` so it's easy to spot and clean.
GITLAB_TEST_IID=
